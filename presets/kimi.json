{
  "cli": "kimi",
  "flags": {
    "prompt": "--print --final-message-only -p",
    "continue": "-C",
    "session": "-S",
    "workdir": "-w"
  },
  "max_retries": 3,
  "status_file": ".relay_status",
  "worktree": {
    "enabled": true,
    "base_dir": ".worktrees"
  },
  "hooks": {
    "post_review": ""
  }
}
